Bootstrap: docker
From: mrtrix3/mrtrix3:latest

%files
    process_dti.sh /app/process_dti.sh

%post
    set -e # Exit on any error
    echo "INFO: Setting up NeuroDebian repository for FSL..."
    apt-get update
    apt-get install -y --no-install-recommends wget gnupg lsb-release curl ca-certificates
    DISTRO=$(lsb_release -cs)
    echo "deb http://neuro.debian.net/debian ${DISTRO} main contrib non-free" \
        | tee /etc/apt/sources.list.d/neurodebian.sources.list
    wget -O- "http://neuro.debian.net/_static/neuro.debian.net.asc" \
        | gpg --dearmor | tee /etc/apt/trusted.gpg.d/neurodebian.gpg > /dev/null
    apt-get update

    echo "INFO: Installing AFNI dependencies..."
    apt-get install -y --no-install-recommends \
        tcsh libnetpbm11 libxmu6 libxpm4 libxt6 libx11-6 libxext6 \
        libglu1-mesa libgl1 libgomp1 \
        libxft2 libgslcblas0 libgsl27

    # libpng12-0 and libxp6 are not in Bookworm; extract .so files from Debian archive
    echo "INFO: Installing legacy libraries from Debian archive..."
    curl -fL -o /tmp/libpng12.deb \
        "https://archive.debian.org/debian/pool/main/libp/libpng/libpng12-0_1.2.50-2+deb8u3_amd64.deb"
    curl -fL -o /tmp/libxp6.deb \
        "https://archive.debian.org/debian/pool/main/libx/libxp/libxp6_1.0.2-2_amd64.deb"
    mkdir -p /tmp/legacy_libs
    dpkg-deb -x /tmp/libpng12.deb /tmp/legacy_libs
    dpkg-deb -x /tmp/libxp6.deb /tmp/legacy_libs
    cp /tmp/legacy_libs/lib/x86_64-linux-gnu/libpng12.so.0 /usr/lib/x86_64-linux-gnu/
    cp /tmp/legacy_libs/usr/lib/x86_64-linux-gnu/libXp.so.6 /usr/lib/x86_64-linux-gnu/
    rm -rf /tmp/legacy_libs /tmp/libpng12.deb /tmp/libxp6.deb

    # AFNI binary was compiled against older libgsl.so.0
    if [ -f /usr/lib/x86_64-linux-gnu/libgsl.so.27 ] && [ ! -f /usr/lib/x86_64-linux-gnu/libgsl.so.0 ]; then
        ln -s libgsl.so.27 /usr/lib/x86_64-linux-gnu/libgsl.so.0
    fi

    echo "INFO: Installing AFNI from precompiled binaries..."
    curl -fL "https://afni.nimh.nih.gov/pub/dist/tgz/linux_openmp_64.tgz" \
        | tar -xz -C /opt
    ln -s /opt/linux_openmp_64 /opt/afni

    echo "INFO: Verifying FSL installation..."
    if [ ! -d "/opt/fsl" ] || [ ! -x "/opt/fsl/bin/fslmaths" ]; then
        echo "WARN: FSL not found at /opt/fsl, installing FSL..."
        apt-get install -y --no-install-recommends fsl
        if [ -d "/usr/share/fsl" ] && [ ! -d "/opt/fsl" ]; then
            ln -s /usr/share/fsl /opt/fsl
        fi
    fi

    # -------------------------------------------------------------------------
    # ANTs v2.6.5 — precompiled Ubuntu 22.04 amd64 build (Debian 12 compatible).
    # Used by process_dti.sh -f (ANTs SyN warping of DTI maps to a template).
    # NOTE: /opt/ants is already used by the mrtrix3 base image (N4 stub only),
    # so full ANTs is installed to /opt/antsx to avoid overwriting it.
    # -------------------------------------------------------------------------
    echo "INFO: Installing ANTs 2.6.5..."
    apt-get install -y --no-install-recommends unzip
    ANTS_URL="https://github.com/ANTsX/ANTs/releases/download/v2.6.5/ants-2.6.5-ubuntu-22.04-X64-gcc.zip"
    wget -q -O /tmp/ants.zip "${ANTS_URL}"
    mkdir -p /opt/antsx
    unzip -q /tmp/ants.zip -d /tmp/ants_extracted
    mv /tmp/ants_extracted/ants-*/bin /opt/antsx/bin
    mv /tmp/ants_extracted/ants-*/lib /opt/antsx/lib
    rm -rf /tmp/ants.zip /tmp/ants_extracted
    echo "INFO: ANTs installation complete — $(ls /opt/antsx/bin | wc -l) binaries installed"

    echo "INFO: Installing Python dependencies..."
    apt-get install -y --no-install-recommends python3 python3-pip
    rm -rf /var/lib/apt/lists/*
    echo "INFO: Setting up DTI processing script..."
    chmod +x /app/process_dti.sh

%environment
    export FSLOUTPUTTYPE=NIFTI_GZ
    export FSLDIR="/opt/fsl"
    export ANTSPATH="/opt/antsx/bin"
    export LD_LIBRARY_PATH="/opt/antsx/lib:${LD_LIBRARY_PATH:-}"
    export PATH="/opt/fsl/bin:/opt/afni:/opt/antsx/bin:$PATH"

%runscript
    exec /app/process_dti.sh "$@"